.venv/
.venv-fi/
.env
__pycache__/
*.pyc

# Python packaging artifacts (from `pip install .` / wheel builds)
*.egg-info/
/build/
/dist/

# fuzzing artifacts and build outputs
workspace/*/out/
workspace/*/targets/
# cloned/compiled third-party sources (libpng, zlib, ...) — rebuilt via build.sh
workspace/*/build/
# generated localization artifacts (regenerated by FI / cov replay)
workspace/*/fi_out/
workspace/*/fi_proj/
workspace/*/in_single/
workspace/*/in_pngsuite/

# generated source variants (clean/patched/per-iteration); keep canonical only
workspace/*/src/*_clean.c
workspace/*/src/*_clean_tmp.c
workspace/*/src/*_patched.c
workspace/*/src/*_llm*.c
workspace/*/src/*_iter*.c
workspace/*/src/*_agent.c

# regenerable dmg2img crash variant (see make_seed.py)
workspace/dmg2img/max.dmg
workspace/libtpms/NVChip
CLAUDE.md
docs/*.pdf

# CC-as-analyst (Mode 1) transient per-run state
.analyst_state.json
workspace/*/.analyst_state.json

# adaptive-campaign run artifacts (rounds, crashes, coverage)
workspace/*/campaign/
