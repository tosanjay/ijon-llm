    "plain":    ["bash", "build.sh", "plain"],
    "describe": ["bash", "build.sh", "describe"],
    "agent":    ["bash", "build.sh", "agent"]
  },
  "targets": {
    "plain": "targets/coap_pdu_plain",
    "agent": "targets/coap_pdu_agent"
  }
}
