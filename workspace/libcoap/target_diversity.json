{
  "name": "libcoap",
  "source_name": "libcoap CoAP PDU parse path (option-sequence diversity)",
  "annotate": "library",
  "fairness_gate": false,
  "library_src": "build/libcoap/src",
  "localize": {
    "fi": "fi_out/fuzzerLogFile-coap_pdu_fuzzer.data.yaml",
    "cov": "build/cov/coverage.json"
  },
